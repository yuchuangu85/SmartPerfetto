# Server Configuration
PORT=3001
NODE_ENV=production

# AI Service Configuration
# Choose one: openai or claude
AI_SERVICE=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Claude Configuration
ANTHROPIC_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# File Upload
MAX_FILE_SIZE=2147483648  # 2GB
UPLOAD_DIR=./uploads

# CORS
FRONTEND_URL=https://smartperfetto.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_1Oxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_1Oyyyy

# Database Configuration (PostgreSQL)
POSTGRES_DB=smartperfetto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://postgres:your-postgres-password@postgres:5432/smartperfetto

# Redis Configuration
REDIS_URL=redis://redis:6379

# Frontend Configuration
VITE_API_URL=https://api.smartperfetto.com