# Server Configuration
PORT=3000
NODE_ENV=development

# AI Service Configuration
# Choose one: openai, claude, or deepseek
AI_SERVICE=deepseek

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4

# Claude Configuration
# ANTHROPIC_API_KEY=your_claude_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# DeepSeek Configuration (recommended)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# File Upload
MAX_FILE_SIZE=2147483648  # 2GB
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# CORS
FRONTEND_URL=http://localhost:10000
