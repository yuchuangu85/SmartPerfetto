# Server Configuration
PORT=3000
NODE_ENV=development

# API Authentication (recommended in any shared environment)
# SMARTPERFETTO_API_KEY=replace_with_a_strong_random_secret

# AI Service Configuration
# Default runtime is agentv3 (Claude Agent SDK) when AI_SERVICE is unset.
# Set AI_SERVICE=deepseek only for the deprecated agentv2 fallback.
# AI_SERVICE=claude-code

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.4

# Claude Configuration
# ANTHROPIC_API_KEY=your_claude_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6
# SMARTPERFETTO_OUTPUT_LANGUAGE=zh-CN  # User-facing output language: zh-CN (default) or en

# DeepSeek Configuration (legacy agentv2 fallback)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenAI-compatible DeepSeek endpoint also supports: https://api.deepseek.com/v1
# Note: /v1 here is API path compatibility only, not model version.
DEEPSEEK_MODEL=deepseek-v4-flash
# deepseek-v4-flash = efficient DeepSeek V4 path
# deepseek-v4-pro = stronger DeepSeek V4 path
# deepseek-chat / deepseek-reasoner are legacy compatibility aliases.
# Optional dedicated reasoning model for fallback after provider/model failures
# DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
# Router order (default): glm-5.1 -> deepseek-v4-pro -> deepseek-v4-flash
# Optional override:
# MODEL_DEFAULT=glm-5.1
# MODEL_FALLBACK_CHAIN=deepseek-v4-pro,deepseek-v4-flash
# Native OpenAI-compatible invocation defaults (enabled by default)
# MODEL_NATIVE_OPTIONS_ENABLED=true
# MODEL_NATIVE_TOOLS=[{"type":"function","function":{"name":"inspect_trace","description":"Inspect trace signals","parameters":{"type":"object","properties":{"focus":{"type":"string"}}}}}]
# MODEL_NATIVE_TOOL_CHOICE=auto
# MODEL_NATIVE_REASONING={"effort":"medium"}
# Optional per-task reasoning override (JSON object)
# MODEL_NATIVE_REASONING_BY_TASK={"planning":{"effort":"high"},"evaluation":{"effort":"high"},"formatting":{"effort":"low"}}

# GLM (Zhipu AI) Configuration
# GLM_API_KEY=your_glm_api_key_here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_CODING_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# GLM_MODEL=glm-5.1

# Strict startup guard for trace-analysis AI credentials.
# When true, backend startup fails fast if required env (e.g. DEEPSEEK_API_KEY) is missing.
TRACE_ANALYSIS_STRICT_STARTUP=false

# File Upload
MAX_FILE_SIZE=2147483648  # 2GB
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# CORS
FRONTEND_URL=http://localhost:10000

# Agent feature flags
FEATURE_AGENT_SCENE_RECONSTRUCT=true
FEATURE_AGENT_LOGS_API=true

# ADB full-mode guard (default false). Requires this flag AND per-request allowAgentFullMode=true.
SMARTPERFETTO_ALLOW_AGENT_ADB_FULL_MODE=false
