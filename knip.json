{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "package.json",
        ".github/workflows/*.yml",
        ".github/dependabot.yml",
        "Dockerfile",
        "docker-compose*.yml",
        "start.sh",
        "scripts/*.sh"
      ],
      "project": ["package.json", ".github/**/*.yml", "Dockerfile", "docker-compose*.yml", "start.sh", "scripts/*.sh"]
    },
    "backend": {
      "entry": [
        "package.json",
        "src/index.ts",
        "src/cli-user/bin.ts",
        "src/scripts/**/*.ts",
        "src/**/*.test.ts",
        "src/**/__tests__/**/*.ts",
        "tests/**/*.ts"
      ],
      "project": ["package.json", "src/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"],
      "ignoreDependencies": ["jest", "tsx"],
      "ignoreBinaries": ["jest", "tsx"]
    }
  },
  "ignore": [
    "frontend/**",
    "perfetto/**",
    "docs/**",
    "backend/public/**",
    "backend/skills/**",
    "backend/strategies/**"
  ],
  "ignoreDependencies": ["@types/*"],
  "ignoreBinaries": ["shellcheck", "tsc"]
}
