{
  "name": "@gracker/smartperfetto",
  "version": "1.0.0",
  "description": "SmartPerfetto CLI and backend runtime",
  "main": "dist/index.js",
  "bin": {
    "smp": "./dist/cli-user/bin.js",
    "smartperfetto": "./dist/cli-user/bin.js"
  },
  "files": [
    "dist/**/*",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "data/perfettoSqlIndex.light.json",
    "data/perfettoSqlIndex.json",
    "data/perfettoStdlibSymbols.json",
    "skills/**/*",
    "strategies/**/*",
    ".env.example",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "clean": "node scripts/clean-dist.cjs",
    "build": "npm run clean && tsc && node scripts/copy-runtime-assets.cjs",
    "start": "node dist/index.js",
    "cli:dev": "tsx src/cli-user/bin.ts",
    "cli:build-run": "npm run build && node dist/cli-user/bin.js",
    "cli:debug": "npm run build && node dist/cli-user/bin.js",
    "cli:pack-check": "npm run build && node scripts/check-cli-pack.cjs",
    "stdlib:generate-symbol-index": "node scripts/generate-stdlib-symbol-index.cjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:core": "jest --runInBand --forceExit src/agent/communication/__tests__/agentMessageBus.test.ts src/agent/core/executors/__tests__/strategyExecutor.test.ts src/agent/core/executors/__tests__/hypothesisExecutor.test.ts src/agent/context/__tests__/enhancedSessionContext.test.ts src/tests/adbTools.test.ts src/services/__tests__/sessionLogger.test.ts src/services/__tests__/traceAnalysisSkillConfig.test.ts src/agent/agents/domain/__tests__/registry.test.ts src/agentv3/__tests__/sqlIncludeInjector.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=src/tests",
    "test:skill-eval": "jest --testPathPatterns=tests/skill-eval --runInBand --testTimeout=120000 --forceExit",
    "test:skill-eval:real-traces": "jest --runInBand --testTimeout=180000 --forceExit tests/skill-eval/scrolling_analysis.eval.ts tests/skill-eval/startup_analysis.eval.ts",
    "test:scene-trace-regression": "TP_PORT_MIN=9800 TP_PORT_MAX=9899 tsx tests/skill-eval/scene_trace_regression.ts",
    "test:state-timeline-regression": "TP_PORT_MIN=9800 TP_PORT_MAX=9899 tsx tests/skill-eval/state_timeline_regression.ts",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand --forceExit",
    "test:agent-eval": "tsx tests/agent-eval/evaluationRunner.ts",
    "test:gate": "npm run test:core && npm run test:scene-trace-regression",
    "test:full": "jest --runInBand --forceExit",
    "test:all": "npm run test:gate",
    "trace-processor:ensure": "node scripts/ensure-trace-processor.cjs",
    "verify:pr": "npm run validate:skills && npm run validate:strategies && npm run typecheck && npm run build && node scripts/check-cli-pack.cjs && npm run test:core && npm run trace-processor:ensure && npm run test:scene-trace-regression",
    "skill:validate": "tsx src/cli/index.ts validate",
    "validate:skills": "tsx src/cli/index.ts validate --contracts --all",
    "validate:strategies": "tsx src/cli/index.ts validate --strategies",
    "skill-notes:promote": "tsx src/agentv3/selfImprove/promoteSkillNote.ts",
    "self-improve:migrate-failure-mode-hash": "tsx src/agentv3/selfImprove/migrateFailureModeHash.ts",
    "skill:test": "tsx src/cli/index.ts test",
    "skill:smoke": "tsx src/cli/index.ts smoke",
    "skill:list": "tsx src/cli/index.ts list",
    "test:scrolling": "tsx src/scripts/runScrollingTest.ts",
    "test:scrolling:real": "tsx src/scripts/runScrollingTestRealData.ts",
    "verify:agent-sse-scrolling": "tsx src/scripts/verifyAgentSseScrolling.ts",
    "generate:frontend-types": "tsx scripts/generateFrontendTypes.ts",
    "check:types": "tsx scripts/checkTypesSync.ts",
    "types": "npm run generate:frontend-types"
  },
  "keywords": [
    "perfetto",
    "android",
    "performance",
    "ai"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.8",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.1",
    "multer": "^2.0.2",
    "openai": "^6.35.0",
    "uuid": "^9.0.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^7.2.0",
    "glob": "^13.0.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}
