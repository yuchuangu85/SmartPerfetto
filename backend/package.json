{
  "name": "smart-perfetto-backend",
  "version": "1.0.0",
  "description": "SmartPerfetto backend API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=src/tests",
    "test:skill-eval": "jest --testPathPatterns=tests/skill-eval --runInBand --testTimeout=120000 --forceExit",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand --forceExit",
    "test:agent-eval": "tsx tests/agent-eval/evaluationRunner.ts",
    "test:all": "jest --runInBand --forceExit",
    "skill:validate": "tsx src/cli/index.ts validate",
    "skill:test": "tsx src/cli/index.ts test",
    "skill:list": "tsx src/cli/index.ts list",
    "test:scrolling": "tsx src/scripts/runScrollingTest.ts",
    "test:scrolling:real": "tsx src/scripts/runScrollingTestRealData.ts"
  },
  "keywords": [
    "perfetto",
    "android",
    "performance",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node-fetch": "^2.6.13",
    "@types/uuid": "^9.0.8",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "js-yaml": "^4.1.1",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.10.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^6.0.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "glob": "^13.0.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}
