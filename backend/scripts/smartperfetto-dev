#
# Development wrapper: runs the CLI via tsx without compiling.
# Usage: ./backend/scripts/smartperfetto-dev analyze <trace> ...
#
# For production use, run `npm run build` then `smartperfetto` after `npm link`.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$(dirname "$SCRIPT_DIR")"
exec npx --prefix "$BACKEND_DIR" tsx "$BACKEND_DIR/src/cli-user/bin.ts" "$@"
