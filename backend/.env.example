# Server Configuration
PORT=3000
NODE_ENV=development

# API Authentication (recommended in any shared environment)
# If set, all protected APIs require:
#   Authorization: Bearer <SMARTPERFETTO_API_KEY>
# or x-api-key header.
# SMARTPERFETTO_API_KEY=replace_with_a_strong_random_secret

# Optional request throttling (in-memory, per API key/IP)
# SMARTPERFETTO_USAGE_MAX_REQUESTS=200
# SMARTPERFETTO_USAGE_MAX_TRACE_REQUESTS=100
# SMARTPERFETTO_USAGE_WINDOW_MS=86400000

# AI Service Configuration
# Choose one: deepseek | openai | anthropic | glm
AI_SERVICE=deepseek

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Anthropic Configuration
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# DeepSeek Configuration (recommended)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (Zhipu AI) Configuration
# GLM_API_KEY=your_glm_api_key_here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4

# LLM Adapter reliability controls (legacy expert path)
# LLM_REQUEST_TIMEOUT_MS=45000
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY_MS=600
# LLM_MAX_RETRY_DELAY_MS=5000

# Agent task safety limits
# AGENT_SQL_MAX_ROWS=1000
# AGENT_SQL_TABLE_CACHE_TTL_MS=300000
# AGENT_TASK_TIMEOUT_MS=180000

# File Upload
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# CORS
FRONTEND_URL=http://localhost:10000
