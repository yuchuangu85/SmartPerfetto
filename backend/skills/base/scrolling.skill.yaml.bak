# =============================================================================
# 滑动卡顿分析 Skill (Scrolling/Jank Analysis) - Expert Edition
# =============================================================================
# 版本: 3.0.0
# 作者: SmartPerfetto Team
# 最后更新: 2025-01
#
# 【分析方法论】
# 专家级分析不是一股脑执行所有SQL，而是分层递进：
# 1. 先识别滑动区间（按压滑动 + Fling）
# 2. 在每个区间内找到掉帧点
# 3. 针对每个掉帧点进行深度分析
# 4. 最终汇总所有区间的统计数据
#
# 【滑动区间划分】
# - 按压滑动(Touch/Scroll)：手指在屏幕上，View根据input报点更新
# - Fling：手指离开屏幕后，View根据滑动曲线计算位置
# - 一次完整滑动 = 按压滑动 + Fling
# - FPS分别统计：完整滑动FPS + Fling FPS
#
# 【核心理念】
# - 过程展示很重要（每个掉帧的位置和原因）
# - 以一次完整滑动为分析单元
# - 一份Trace可能有多个滑动区间，需分别分析
# - 最终汇总：所有区间的FPS、掉帧个数、原因分析
# =============================================================================

name: scrolling_analysis
version: "3.0.0"
type: performance
category: rendering
priority: high
sop_doc: scrolling.sop.md

# 分析模式：分层递进
analysis_mode: hierarchical

meta:
  display_name: "滑动卡顿分析"
  description: "专家级滑动分析：识别滑动区间 → 定位掉帧 → 逐帧分析原因"
  icon: "chart-line"
  tags:
    - scrolling
    - jank
    - fps
    - fling
    - touch_scroll
    - frame_analysis

triggers:
  keywords:
    zh:
      - 滑动
      - 卡顿
      - 帧率
      - 掉帧
      - 丢帧
      - FPS
      - 流畅度
      - 列表滑动
      - RecyclerView
      - Fling
    en:
      - scroll
      - jank
      - fps
      - frame
      - fling
      - stutter
      - smoothness

  patterns:
    - ".*滑动.*卡.*"
    - ".*卡顿.*"
    - ".*掉帧.*"
    - ".*jank.*"
    - ".*fling.*"

prerequisites:
  required_tables:
    - slice
    - thread
    - process

  optional_tables:
    - expected_frame_timeline_slice
    - actual_frame_timeline_slice
    - sched_slice
    - thread_state

  modules:
    - android.frames.timeline

# =============================================================================
# 分层分析流程
# =============================================================================
#
# Layer 1: 环境检测 & 滑动区间识别
#   ├── 检测刷新率
#   ├── 识别所有滑动区间
#   └── 区分按压滑动 vs Fling
#
# Layer 2: 区间级分析（对每个滑动区间）
#   ├── 计算区间内所有帧
#   ├── 识别掉帧帧
#   └── 计算区间FPS统计
#
# Layer 3: 帧级分析（对每个掉帧帧）
#   ├── 分析该帧的主线程耗时
#   ├── 分析该帧的RenderThread
#   ├── 分析该帧的CPU调度
#   ├── 分析该帧的Buffer状态
#   └── 得出该帧掉帧原因
#
# Layer 4: 汇总报告
#   ├── 所有区间的FPS对比
#   ├── 所有掉帧的原因分类统计
#   └── 优化建议
# =============================================================================

layers:
  # ===========================================================================
  # Layer 1: 环境检测与滑动区间识别
  # ===========================================================================
  - id: layer1_detection
    name: "环境检测与区间识别"
    description: "检测刷新率，识别所有滑动区间"

    steps:
      # Step 1.1: 检测刷新率
      - id: detect_refresh_rate
        name: "检测设备刷新率"
        sql: |
          WITH vsync_intervals AS (
            SELECT
              ts,
              LEAD(ts) OVER (ORDER BY ts) - ts AS interval_ns
            FROM slice s
            JOIN thread_track tt ON s.track_id = tt.id
            JOIN thread t ON tt.utid = t.utid
            JOIN process p ON t.upid = p.upid
            WHERE (p.name = 'surfaceflinger' OR p.name LIKE '%surfaceflinger%')
              AND (s.name GLOB '*VSYNC*' OR s.name GLOB '*vsync-sf*')
            LIMIT 200
          )
          SELECT
            CASE
              WHEN AVG(interval_ns) < 9000000 THEN 120
              WHEN AVG(interval_ns) < 13000000 THEN 90
              ELSE 60
            END AS refresh_rate_hz,
            CASE
              WHEN AVG(interval_ns) < 9000000 THEN 8.33
              WHEN AVG(interval_ns) < 13000000 THEN 11.11
              ELSE 16.67
            END AS vsync_period_ms
          FROM vsync_intervals
          WHERE interval_ns > 5000000 AND interval_ns < 30000000
        save_as: refresh_rate

      # Step 1.2: 识别所有滑动区间（通过 Input 事件）
      - id: identify_scroll_sessions
        name: "识别滑动区间"
        description: |
          通过 Input 事件识别滑动区间：
          - ACTION_DOWN: 滑动开始
          - ACTION_MOVE: 按压滑动中
          - ACTION_UP: 手指抬起，可能进入 Fling
          - Fling 通过 VelocityTracker 或 Scroller 识别
        sql: |
          WITH input_events AS (
            SELECT
              s.ts,
              s.dur,
              s.name,
              CASE
                WHEN s.name GLOB '*ACTION_DOWN*' OR s.name GLOB '*MotionEvent*DOWN*' THEN 'DOWN'
                WHEN s.name GLOB '*ACTION_MOVE*' OR s.name GLOB '*MotionEvent*MOVE*' THEN 'MOVE'
                WHEN s.name GLOB '*ACTION_UP*' OR s.name GLOB '*MotionEvent*UP*' THEN 'UP'
                WHEN s.name GLOB '*ACTION_CANCEL*' THEN 'CANCEL'
                ELSE 'OTHER'
              END AS action_type
            FROM slice s
            JOIN thread_track tt ON s.track_id = tt.id
            JOIN thread t ON tt.utid = t.utid
            JOIN process p ON t.upid = p.upid
            WHERE p.name GLOB '${package}*'
              AND t.tid = p.pid
              AND (s.name GLOB '*Input*'
                   OR s.name GLOB '*Motion*'
                   OR s.name GLOB '*Touch*'
                   OR s.name GLOB '*deliverInputEvent*')
            ORDER BY s.ts
          ),
          -- 标记每个DOWN开始一个新的滑动session
          session_markers AS (
            SELECT
              ts,
              action_type,
              SUM(CASE WHEN action_type = 'DOWN' THEN 1 ELSE 0 END)
                OVER (ORDER BY ts) AS session_id
            FROM input_events
            WHERE action_type IN ('DOWN', 'MOVE', 'UP', 'CANCEL')
          ),
          -- 计算每个session的边界
          sessions AS (
            SELECT
              session_id,
              MIN(ts) AS session_start_ts,
              MAX(ts) AS session_end_ts,
              COUNT(CASE WHEN action_type = 'MOVE' THEN 1 END) AS move_count
            FROM session_markers
            WHERE session_id > 0
            GROUP BY session_id
            HAVING move_count > 3  -- 至少3个MOVE才算有效滑动
          )
          SELECT
            session_id,
            session_start_ts / 1e6 AS start_ms,
            session_end_ts / 1e6 AS end_ms,
            (session_end_ts - session_start_ts) / 1e6 AS duration_ms,
            move_count
          FROM sessions
          ORDER BY session_start_ts
        save_as: scroll_sessions

      # Step 1.3: 识别 Fling 区间
      - id: identify_fling_sessions
        name: "识别 Fling 区间"
        description: |
          Fling 区间特征：
          - 手指抬起后的滑动
          - 通过 Scroller/OverScroller 或 fling 相关 trace 识别
          - 或者通过连续帧渲染但无 Input 事件识别
        sql: |
          WITH fling_markers AS (
            SELECT
              s.ts,
              s.dur,
              s.name
            FROM slice s
            JOIN thread_track tt ON s.track_id = tt.id
            JOIN thread t ON tt.utid = t.utid
            JOIN process p ON t.upid = p.upid
            WHERE p.name GLOB '${package}*'
              AND (s.name GLOB '*fling*'
                   OR s.name GLOB '*Fling*'
                   OR s.name GLOB '*Scroller*'
                   OR s.name GLOB '*OverScroller*'
                   OR s.name GLOB '*VelocityTracker*')
          ),
          fling_groups AS (
            SELECT
              ts,
              dur,
              name,
              -- 如果两个fling事件间隔超过500ms，认为是不同的fling
              SUM(CASE
                WHEN ts - LAG(ts) OVER (ORDER BY ts) > 500000000 THEN 1
                ELSE 0
              END) OVER (ORDER BY ts) AS fling_session_id
            FROM fling_markers
          )
          SELECT
            fling_session_id,
            MIN(ts) / 1e6 AS fling_start_ms,
            MAX(ts + dur) / 1e6 AS fling_end_ms,
            (MAX(ts + dur) - MIN(ts)) / 1e6 AS fling_duration_ms,
            COUNT(*) AS fling_event_count
          FROM fling_groups
          GROUP BY fling_session_id
          ORDER BY fling_start_ms
        save_as: fling_sessions
        optional: true

      # Step 1.4: 构建完整滑动区间（按压 + Fling）
      - id: build_complete_scroll_sessions
        name: "构建完整滑动区间"
        description: "将按压滑动和对应的Fling合并为完整的滑动区间"
        sql: |
          -- 这个查询将scroll_sessions和fling_sessions关联起来
          -- 如果fling发生在scroll结束后的合理时间内，认为是同一次滑动
          WITH scroll_data AS (
            SELECT
              session_id,
              session_start_ts,
              session_end_ts,
              move_count,
              'touch_scroll' AS phase
            FROM (
              SELECT
                ROW_NUMBER() OVER (ORDER BY MIN(ts)) AS session_id,
                MIN(ts) AS session_start_ts,
                MAX(ts) AS session_end_ts,
                COUNT(*) AS move_count
              FROM slice s
              JOIN thread_track tt ON s.track_id = tt.id
              JOIN thread t ON tt.utid = t.utid
              JOIN process p ON t.upid = p.upid
              WHERE p.name GLOB '${package}*'
                AND t.tid = p.pid
                AND s.name GLOB '*Choreographer#doFrame*'
              GROUP BY s.ts / 1000000000  -- 按秒分组，粗略分割
            )
          )
          SELECT
            session_id AS scroll_id,
            session_start_ts / 1e6 AS start_ms,
            session_end_ts / 1e6 AS end_ms,
            (session_end_ts - session_start_ts) / 1e6 AS duration_ms,
            'complete' AS session_type
          FROM scroll_data
          ORDER BY session_start_ts
        save_as: complete_scroll_sessions

  # ===========================================================================
  # Layer 2: 区间级帧分析
  # ===========================================================================
  - id: layer2_session_analysis
    name: "区间级帧分析"
    description: "对每个滑动区间分析帧数据"
    depends_on: layer1_detection

    # 这个layer会对每个scroll_session执行
    iterate_over: complete_scroll_sessions

    steps:
      # Step 2.1: 获取区间内所有帧
      - id: get_session_frames
        name: "获取区间内所有帧"
        sql: |
          SELECT
            s.ts / 1e6 AS ts_ms,
            s.dur / 1e6 AS dur_ms,
            s.ts AS ts_ns,
            s.dur AS dur_ns,
            ROW_NUMBER() OVER (ORDER BY s.ts) AS frame_number
          FROM slice s
          JOIN thread_track tt ON s.track_id = tt.id
          JOIN thread t ON tt.utid = t.utid
          JOIN process p ON t.upid = p.upid
          WHERE p.name GLOB '${package}*'
            AND t.tid = p.pid
            AND s.name GLOB '*Choreographer#doFrame*'
            AND s.ts >= ${session_start_ts}
            AND s.ts <= ${session_end_ts}
          ORDER BY s.ts
        save_as: session_frames

      # Step 2.2: 识别区间内的掉帧
      - id: identify_janky_frames
        name: "识别掉帧帧"
        description: "基于刷新率阈值识别掉帧"
        sql: |
          WITH frames AS (
            SELECT
              s.ts,
              s.dur,
              s.ts / 1e6 AS ts_ms,
              s.dur / 1e6 AS dur_ms,
              LEAD(s.ts) OVER (ORDER BY s.ts) - s.ts AS frame_interval,
              ROW_NUMBER() OVER (ORDER BY s.ts) AS frame_number
            FROM slice s
            JOIN thread_track tt ON s.track_id = tt.id
            JOIN thread t ON tt.utid = t.utid
            JOIN process p ON t.upid = p.upid
            WHERE p.name GLOB '${package}*'
              AND t.tid = p.pid
              AND s.name GLOB '*Choreographer#doFrame*'
              AND s.ts >= ${session_start_ts}
              AND s.ts <= ${session_end_ts}
          )
          SELECT
            frame_number,
            ts_ms,
            dur_ms,
            ts,
            dur,
            CASE
              WHEN dur > 50000000 THEN 'severe'      -- > 50ms 严重掉帧
              WHEN dur > 33000000 THEN 'bad'         -- > 33ms 掉2帧
              WHEN dur > ${vsync_period_ns} THEN 'jank'  -- 超过1个vsync周期
              ELSE 'normal'
            END AS jank_level,
            ROUND(dur / 1e6 / ${vsync_period_ms}, 1) AS frames_dropped
          FROM frames
          WHERE dur > ${vsync_period_ns}  -- 只返回掉帧的帧
          ORDER BY ts
        save_as: janky_frames

      # Step 2.3: 计算区间 FPS 统计
      - id: calculate_session_fps
        name: "计算区间FPS"
        sql: |
          WITH frames AS (
            SELECT
              s.ts,
              s.dur,
              LEAD(s.ts) OVER (ORDER BY s.ts) - s.ts AS frame_interval
            FROM slice s
            JOIN thread_track tt ON s.track_id = tt.id
            JOIN thread t ON tt.utid = t.utid
            JOIN process p ON t.upid = p.upid
            WHERE p.name GLOB '${package}*'
              AND t.tid = p.pid
              AND s.name GLOB '*Choreographer#doFrame*'
              AND s.ts >= ${session_start_ts}
              AND s.ts <= ${session_end_ts}
          )
          SELECT
            COUNT(*) AS total_frames,
            SUM(CASE WHEN dur > ${vsync_period_ns} THEN 1 ELSE 0 END) AS janky_frames,
            SUM(CASE WHEN dur > ${vsync_period_ns} * 2 THEN 1 ELSE 0 END) AS severe_janky_frames,
            ROUND(AVG(dur) / 1e6, 2) AS avg_frame_time_ms,
            ROUND(MAX(dur) / 1e6, 2) AS max_frame_time_ms,
            ROUND(1000.0 / (AVG(frame_interval) / 1e6), 1) AS avg_fps,
            ROUND(100.0 * SUM(CASE WHEN dur > ${vsync_period_ns} THEN 1 ELSE 0 END) / COUNT(*), 2) AS jank_rate_percent,
            ${session_id} AS session_id
          FROM frames
          WHERE frame_interval IS NOT NULL
            AND frame_interval > 0
            AND frame_interval < 1000000000
        save_as: session_fps_stats

  # ===========================================================================
  # Layer 3: 帧级深度分析（对每个掉帧）
  # ===========================================================================
  - id: layer3_frame_analysis
    name: "帧级深度分析"
    description: "对每个掉帧帧进行深度原因分析"
    depends_on: layer2_session_analysis

    # 对每个掉帧帧执行
    iterate_over: janky_frames

    steps:
      # Step 3.1: 分析该帧的主线程活动
      - id: analyze_main_thread
        name: "主线程分析"
        description: "分析该掉帧帧期间主线程在做什么"
        sql: |
          SELECT
            s.name AS operation,
            s.ts / 1e6 AS ts_ms,
            s.dur / 1e6 AS dur_ms,
            s.depth,
            ROUND(100.0 * s.dur / ${frame_dur_ns}, 1) AS time_percent
          FROM slice s
          JOIN thread_track tt ON s.track_id = tt.id
          JOIN thread t ON tt.utid = t.utid
          JOIN process p ON t.upid = p.upid
          WHERE p.name GLOB '${package}*'
            AND t.tid = p.pid
            AND s.ts >= ${frame_ts_ns}
            AND s.ts < ${frame_ts_ns} + ${frame_dur_ns}
            AND s.dur > 1000000  -- > 1ms
            AND s.name NOT GLOB '*Choreographer*'
          ORDER BY s.dur DESC
          LIMIT 10
        save_as: frame_main_thread_ops

      # Step 3.2: 分析该帧的 RenderThread 活动
      - id: analyze_render_thread
        name: "RenderThread 分析"
        sql: |
          SELECT
            s.name AS operation,
            s.ts / 1e6 AS ts_ms,
            s.dur / 1e6 AS dur_ms,
            ROUND(100.0 * s.dur / ${frame_dur_ns}, 1) AS time_percent
          FROM slice s
          JOIN thread_track tt ON s.track_id = tt.id
          JOIN thread t ON tt.utid = t.utid
          JOIN process p ON t.upid = p.upid
          WHERE p.name GLOB '${package}*'
            AND t.name = 'RenderThread'
            AND s.ts >= ${frame_ts_ns}
            AND s.ts < ${frame_ts_ns} + ${frame_dur_ns}
            AND s.dur > 500000  -- > 0.5ms
          ORDER BY s.dur DESC
          LIMIT 10
        save_as: frame_render_thread_ops

      # Step 3.3: 分析该帧的 CPU 调度状态
      - id: analyze_cpu_scheduling
        name: "CPU 调度分析"
        description: "分析该帧期间主线程和RenderThread的CPU调度"
        sql: |
          WITH target_threads AS (
            SELECT t.utid, t.name AS thread_name
            FROM thread t
            JOIN process p ON t.upid = p.upid
            WHERE p.name GLOB '${package}*'
              AND (t.tid = p.pid OR t.name = 'RenderThread')
          )
          SELECT
            tt.thread_name,
            ts.state,
            ROUND(SUM(ts.dur) / 1e6, 2) AS total_dur_ms,
            ROUND(100.0 * SUM(ts.dur) / ${frame_dur_ns}, 1) AS time_percent,
            COUNT(*) AS state_count
          FROM thread_state ts
          JOIN target_threads tt ON ts.utid = tt.utid
          WHERE ts.ts >= ${frame_ts_ns}
            AND ts.ts < ${frame_ts_ns} + ${frame_dur_ns}
          GROUP BY tt.thread_name, ts.state
          ORDER BY tt.thread_name, total_dur_ms DESC
        save_as: frame_cpu_states
        optional: true

      # Step 3.4: 检查该帧的 Binder 调用
      - id: analyze_binder_calls
        name: "Binder 调用分析"
        sql: |
          SELECT
            s.name AS binder_call,
            s.dur / 1e6 AS dur_ms,
            s.ts / 1e6 AS ts_ms
          FROM slice s
          JOIN thread_track tt ON s.track_id = tt.id
          JOIN thread t ON tt.utid = t.utid
          JOIN process p ON t.upid = p.upid
          WHERE p.name GLOB '${package}*'
            AND t.tid = p.pid
            AND (s.name GLOB '*binder*' OR s.name GLOB '*Binder*')
            AND s.ts >= ${frame_ts_ns}
            AND s.ts < ${frame_ts_ns} + ${frame_dur_ns}
          ORDER BY s.dur DESC
        save_as: frame_binder_calls

      # Step 3.5: 检查 Buffer 操作
      - id: analyze_buffer_ops
        name: "Buffer 操作分析"
        sql: |
          SELECT
            s.name AS buffer_op,
            s.dur / 1e6 AS dur_ms,
            CASE
              WHEN s.dur > 5000000 THEN '长等待'
              WHEN s.dur > 2000000 THEN '中等待'
              ELSE '正常'
            END AS wait_status
          FROM slice s
          JOIN thread_track tt ON s.track_id = tt.id
          JOIN thread t ON tt.utid = t.utid
          JOIN process p ON t.upid = p.upid
          WHERE p.name GLOB '${package}*'
            AND (s.name GLOB '*dequeueBuffer*' OR s.name GLOB '*queueBuffer*')
            AND s.ts >= ${frame_ts_ns}
            AND s.ts < ${frame_ts_ns} + ${frame_dur_ns}
          ORDER BY s.dur DESC
        save_as: frame_buffer_ops

      # Step 3.6: 诊断该帧掉帧原因
      - id: diagnose_frame_jank_cause
        name: "诊断掉帧原因"
        type: diagnosis
        rules:
          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*Binder*'"
            cause: "主线程Binder调用阻塞"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*inflate*'"
            cause: "布局inflate耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*measure*'"
            cause: "View measure耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*layout*'"
            cause: "View layout耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*draw*'"
            cause: "View draw耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*onBind*'"
            cause: "RecyclerView onBindViewHolder耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_main_thread_ops.any.dur_ms > 16 AND frame_main_thread_ops.any.operation GLOB '*GC*'"
            cause: "GC导致主线程暂停"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_render_thread_ops.any.dur_ms > 16 AND frame_render_thread_ops.any.operation GLOB '*syncFrameState*'"
            cause: "RenderThread syncFrameState耗时"
            detail: "${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_render_thread_ops.any.dur_ms > 16 AND frame_render_thread_ops.any.operation GLOB '*DrawFrame*'"
            cause: "RenderThread DrawFrame耗时"
            detail: "GPU渲染复杂，${operation} 耗时 ${dur_ms}ms"

          - condition: "frame_buffer_ops.any.wait_status == '长等待'"
            cause: "Buffer等待(GPU积压)"
            detail: "${buffer_op} 等待 ${dur_ms}ms"

          - condition: "frame_cpu_states.any.state == 'R' AND frame_cpu_states.any.time_percent > 20"
            cause: "CPU调度延迟(Runnable等待)"
            detail: "${thread_name} Runnable状态占比 ${time_percent}%"

          - default: true
            cause: "需进一步分析"
            detail: "帧耗时 ${frame_dur_ms}ms"
        save_as: frame_jank_diagnosis

  # ===========================================================================
  # Layer 4: 汇总报告
  # ===========================================================================
  - id: layer4_summary
    name: "汇总报告"
    description: "汇总所有滑动区间的分析结果"
    depends_on: layer3_frame_analysis

    steps:
      # Step 4.1: 汇总所有区间的 FPS
      - id: summarize_all_sessions
        name: "所有区间 FPS 汇总"
        type: aggregate
        from: session_fps_stats
        sql: |
          SELECT
            session_id,
            total_frames,
            janky_frames,
            severe_janky_frames,
            avg_frame_time_ms,
            max_frame_time_ms,
            avg_fps,
            jank_rate_percent,
            CASE
              WHEN jank_rate_percent < 1 THEN '优秀'
              WHEN jank_rate_percent < 5 THEN '良好'
              WHEN jank_rate_percent < 10 THEN '一般'
              ELSE '较差'
            END AS quality_level
          FROM all_session_fps_stats
          ORDER BY session_id
        save_as: all_sessions_summary

      # Step 4.2: 汇总所有掉帧原因
      - id: summarize_jank_causes
        name: "掉帧原因汇总"
        type: aggregate
        from: frame_jank_diagnosis
        sql: |
          SELECT
            cause,
            COUNT(*) AS occurrence_count,
            ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER(), 1) AS percentage,
            GROUP_CONCAT(DISTINCT detail, '; ') AS examples
          FROM all_frame_jank_diagnosis
          GROUP BY cause
          ORDER BY occurrence_count DESC
        save_as: jank_causes_summary

      # Step 4.3: 生成所有掉帧的详细列表
      - id: list_all_janky_frames
        name: "所有掉帧详情"
        type: aggregate
        from: janky_frames
        fields:
          - session_id
          - frame_number
          - ts_ms
          - dur_ms
          - jank_level
          - frames_dropped
          - jank_cause
          - jank_detail
        save_as: all_janky_frames_detail

# =============================================================================
# 输出格式
# =============================================================================
output:
  title: "滑动卡顿分析报告"

  # 输出优先展示过程，最后才是总结
  sections:
    # Section 1: 基本信息
    - id: basic_info
      title: "基本信息"
      type: summary
      fields:
        - { from: refresh_rate, key: refresh_rate_hz, label: "设备刷新率", unit: "Hz" }
        - { from: complete_scroll_sessions, key: count, label: "滑动区间数" }

    # Section 2: 所有滑动区间的 FPS 对比（重要）
    - id: sessions_fps_comparison
      title: "各滑动区间 FPS 对比"
      type: table
      from: all_sessions_summary
      description: "每个滑动区间的帧率统计，包括按压滑动和Fling"
      fields:
        - { key: session_id, label: "区间" }
        - { key: total_frames, label: "总帧数" }
        - { key: janky_frames, label: "掉帧数" }
        - { key: avg_fps, label: "平均FPS", unit: "fps" }
        - { key: jank_rate_percent, label: "掉帧率", unit: "%" }
        - { key: quality_level, label: "质量" }

    # Section 3: 所有掉帧详情（最重要 - 过程展示）
    - id: all_janky_frames
      title: "所有掉帧详情"
      type: table
      from: all_janky_frames_detail
      description: "每一帧掉帧的时间、严重程度和原因分析"
      highlight: true
      fields:
        - { key: session_id, label: "区间" }
        - { key: frame_number, label: "帧号" }
        - { key: ts_ms, label: "时间", unit: "ms" }
        - { key: dur_ms, label: "耗时", unit: "ms" }
        - { key: jank_level, label: "严重程度" }
        - { key: frames_dropped, label: "掉帧数" }
        - { key: jank_cause, label: "原因" }
        - { key: jank_detail, label: "详情" }

    # Section 4: 掉帧原因分类统计
    - id: jank_causes
      title: "掉帧原因分类"
      type: pie_chart
      from: jank_causes_summary
      fields:
        - { key: cause, label: "原因" }
        - { key: occurrence_count, label: "次数" }
        - { key: percentage, label: "占比", unit: "%" }

    # Section 5: 优化建议（基于原因统计）
    - id: optimization_suggestions
      title: "优化建议"
      type: suggestions
      based_on: jank_causes_summary
      rules:
        - cause: "主线程Binder调用阻塞"
          suggestions:
            - "将Binder调用移到后台线程"
            - "减少主线程的同步IPC调用"
            - "考虑使用异步Binder"

        - cause: "布局inflate耗时"
          suggestions:
            - "使用ViewStub延迟加载"
            - "减少布局层级"
            - "预加载常用布局"

        - cause: "View measure/layout耗时"
          suggestions:
            - "使用ConstraintLayout减少嵌套"
            - "避免在滑动时触发requestLayout"
            - "检查是否有不必要的多次测量"

        - cause: "RecyclerView onBindViewHolder耗时"
          suggestions:
            - "简化ViewHolder绑定逻辑"
            - "避免在onBind中进行耗时操作"
            - "使用DiffUtil优化更新"
            - "预加载数据"

        - cause: "GC导致主线程暂停"
          suggestions:
            - "减少临时对象创建"
            - "使用对象池"
            - "检查内存泄漏"

        - cause: "RenderThread渲染耗时"
          suggestions:
            - "减少过度绘制"
            - "简化动画效果"
            - "检查GPU过载"

        - cause: "Buffer等待"
          suggestions:
            - "GPU渲染积压，简化渲染内容"
            - "检查是否有GPU密集型操作"

        - cause: "CPU调度延迟"
          suggestions:
            - "检查系统CPU负载"
            - "确保关键线程优先级正确"
            - "检查是否有后台任务抢占CPU"

# =============================================================================
# 判断标准
# =============================================================================
thresholds:
  session_fps:
    unit: fps
    levels:
      excellent: { min: 55 }      # > 55fps
      good: { min: 50, max: 55 }  # 50-55fps
      warning: { min: 40, max: 50 }
      critical: { max: 40 }       # < 40fps

  session_jank_rate:
    unit: percent
    levels:
      excellent: { max: 1 }
      good: { min: 1, max: 5 }
      warning: { min: 5, max: 10 }
      critical: { min: 10 }

# =============================================================================
# 参考资料
# =============================================================================
references:
  - title: "Android Systrace 流畅性实战 1 - 掉帧定义"
    url: "https://www.androidperformance.com/2021/04/24/android-systrace-smooth-in-action-1/"
  - title: "Android Systrace 流畅性实战 2 - 案例分析"
    url: "https://www.androidperformance.com/2021/04/24/android-systrace-smooth-in-action-2/"
  - title: "Android Systrace 流畅性实战 3 - 黄帧与掉帧"
    url: "https://www.androidperformance.com/2021/04/24/android-systrace-smooth-in-action-3/"
  - title: "Perfetto Frame Timeline"
    url: "https://perfetto.dev/docs/data-sources/frametimeline"
